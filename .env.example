# ===================================================================
# AIOS: Secrets. Kopiere diese Datei zu .env und fülle NUR aus,
# was du brauchst. .env ist gitignored und wird NIE geteilt.
# Alles ist optional und später nachrüstbar. Das Onboarding (/aios-setup)
# füllt das gemeinsam mit dir aus.
# ===================================================================

# ---- Kern ----
# Claude läuft normal über deine Claude-Subscription (claude-CLI), KEIN API-Key nötig.
# ANTHROPIC_API_KEY nur, wenn du Server-Automationen ohne CLI fahren willst.
ANTHROPIC_API_KEY=

# ---- Telegram (mobiles Interface + Push-Benachrichtigungen) ----
# Bot bei @BotFather anlegen -> Token. Chat-ID: schreib deinem Bot, dann
# https://api.telegram.org/bot<TOKEN>/getUpdates aufrufen -> "chat":{"id":...}.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_CHAT_ID=

# ---- WhatsApp-Outreach (Meta Cloud API) ----
# Meta for Developers -> App (Business) -> WhatsApp. System-User-Token (läuft nie ab).
WA_ACCESS_TOKEN=
WA_APP_SECRET=
WA_VERIFY_TOKEN=
WA_APP_ID=
WA_PHONE_NUMBER_ID=
WA_WABA_ID=

# ---- Content-Pipeline / Video ----
# APIFY_TOKEN: apify.com -> Settings -> Integrations (Instagram/Web-Scraping).
APIFY_TOKEN=
# DEEPGRAM_API_KEY: deepgram.com (Speech-to-Text; auch für Note Taker).
DEEPGRAM_API_KEY=
# ELEVENLABS: elevenlabs.io (Voice-Over / Video). VOICE_ID = deine geklonte Stimme.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ---- Note Taker / Sales Copilot ----
# nutzt DEEPGRAM_API_KEY (oben). Sprache: de oder en.
STT_LANGUAGE=de

# ---- Google (Gmail/Kalender/Drive für Action-Needed-Signale) ----
# Eigene OAuth-Credentials (Google Cloud Console). Onboarding erklärt den Ablauf.
USER_GOOGLE_EMAIL=
GOOGLE_CREDS_FILE=credentials.json
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---- Optional: Lead-Sourcing Sheet-Export (standardmäßig AUS, schreibt lokal ins CRM) ----
LEAD_SHEET_ID=
OUTREACH_SHEET_ID=
MERGE_SHEET_ID=

# ---- Optional: Finanzen ----
# GoCardless Bank Account Data (kostenlos, Open Banking): bankaccountdata.gocardless.com
GOCARDLESS_SECRET_ID=
GOCARDLESS_SECRET_KEY=
GOCARDLESS_TOKEN=
# Wise -> Settings -> API tokens (read-only).
WISE_API_TOKEN=

# ---- Optional: Graphify (einmaliger Wissensgraph-Bau) ----
# Google AI Studio Free-Tier.
GEMINI_API_KEY=
