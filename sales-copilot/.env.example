# Kopiere diese Datei zu ".env" und trage deine Schlüssel ein.

# Claude läuft über die Subscription (claude-CLI via dashboard/claude-bin.sh) — KEIN API-Key nötig.

# Deepgram API-Key (für die Live-Transkription) — von https://console.deepgram.com
DEEPGRAM_API_KEY=...

# Sprache der Transkription (de = Deutsch, en = Englisch)
STT_LANGUAGE=de
